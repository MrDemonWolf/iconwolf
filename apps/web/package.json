{
  "name": "@mrdemonwolf/iconwolf-web",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build && tsc -p tsconfig.server.json",
    "dev": "concurrently \"vite\" \"tsx watch src/server/index.ts\"",
    "start": "node dist/server/index.js",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "@mrdemonwolf/iconwolf": "workspace:*",
    "hono": "^4.7.0",
    "@hono/node-server": "^1.14.0",
    "archiver": "^7.0.1",
    "unzipper": "^0.12.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/archiver": "^6.0.3",
    "@types/node": "^22.13.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/unzipper": "^0.10.10",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "eslint": "^9.19.0",
    "lucide-react": "^0.511.0",
    "postcss": "^8.5.6",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.55.0",
    "vite": "^6.3.5"
  }
}
